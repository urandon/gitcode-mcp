#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SAFETY_LIB="${SCRIPT_DIR}/lib/safety.sh"

usage() {
  cat <<'USAGE'
Usage: project/dogfood/check-dogfood-feedback <feedback-file>

Validate a dogfood feedback artifact against public-safety rules.

Scans the file for:
  - bearer/API tokens
  - Authorization: headers
  - Cookie: / Set-Cookie: headers
  - token-like high-entropy strings
  - absolute user paths (/Users/<name>/, /home/<name>/, Windows profile paths)
  - private/internal hostnames
  - raw JSON response blocks lacking <REDACTED_RESPONSE> or fixture markers
  - non-allowlisted repo/tracker/wiki identifiers matching documented syntaxes

Output: 'path:line:category:message' findings on stderr.
Fatal findings cause nonzero exit. Warnings are reported separately.

Arguments:
  <feedback-file>   Path to the feedback.md file to validate.

Options:
  -h, --help        Show this help.
USAGE
}

feedback_file=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "${feedback_file}" ]]; then
        feedback_file="$1"
      else
        printf 'check-dogfood-feedback: unexpected extra argument: %s\n' "$1" >&2
        usage >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "${feedback_file}" ]]; then
  printf 'check-dogfood-feedback: missing feedback file argument\n' >&2
  usage >&2
  exit 2
fi

if [[ ! -f "${feedback_file}" ]]; then
  printf 'check-dogfood-feedback: file not found: %s\n' "${feedback_file}" >&2
  exit 2
fi

# shellcheck source=/dev/null
source "${SAFETY_LIB}"
load_fixture_allowlist

fatal_count=0
warn_count=0

emit_fatal() {
  local line="$1" category="$2" message="$3"
  printf '%s:%s:%s:%s\n' "${feedback_file}" "${line}" "${category}" "${message}" >&2
  fatal_count=$((fatal_count + 1))
}

emit_warning() {
  local line="$1" category="$2" message="$3"
  printf '%s:%s:%s:%s\n' "${feedback_file}" "${line}" "${category}" "${message}" >&2
  warn_count=$((warn_count + 1))
}

is_allowlisted_id() {
  local id="$1"
  local allow_id
  for allow_id in "${ALLOWLIST_IDS[@]}"; do
    if [[ -z "${allow_id}" ]]; then
      continue
    fi
    if [[ "${id}" == "${allow_id}" ]]; then
      return 0
    fi
  done
  return 1
}

is_allowlisted_host() {
  local host="$1"
  local allow_host
  for allow_host in "${ALLOWLIST_HOSTS[@]}"; do
    if [[ -z "${allow_host}" ]]; then
      continue
    fi
    if [[ "${host}" == "${allow_host}" ]]; then
      return 0
    fi
  done
  return 1
}

contains_placeholder() {
  local text="$1"
  local placeholder
  for placeholder in "${ALLOWLIST_PLACEHOLDERS[@]}"; do
    if [[ "${text}" == *"${placeholder}"* ]]; then
      return 0
    fi
  done
  return 1
}

is_placeholder_only() {
  local text="$1"
  local stripped="${text}"
  local placeholder
  for placeholder in "${ALLOWLIST_PLACEHOLDERS[@]}"; do
    stripped="${stripped//${placeholder}/}"
  done
  [[ -z "${stripped// /}" ]]
}

line_num=0

while IFS= read -r raw_line || [[ -n "${raw_line}" ]]; do
  line_num=$((line_num + 1))

  line="${raw_line}"
  line_trimmed="${line#"${line%%[![:space:]]*}"}"

  # Bearer/API token patterns
  if echo "${line}" | grep -qE 'Bearer [A-Za-z0-9+/=_-]{20,}'; then
    emit_fatal "${line_num}" "bearer_token" "Bearer token detected"
  fi

  if echo "${line}" | grep -qiE '\b(token|secret|api[_-]?key|access[_-]?key)\s*[:=]\s*[A-Za-z0-9+/=_-]{16,}' <<<"${line}" && ! contains_placeholder "${line}"; then
    if ! echo "${line}" | grep -qiE 'GITCODE_TOKEN|<REDACTED_TOKEN>|<REDACTED_SECRET>|<your-token>|<ci-token>'; then
      emit_fatal "${line_num}" "api_token" "Potential API token/secret assignment detected"
    fi
  fi

  # Authorization headers
  if echo "${line}" | grep -qE 'Authorization:\s*(Bearer|Basic|token)'; then
    emit_fatal "${line_num}" "auth_header" "Authorization header detected"
  fi

  # Cookie / Set-Cookie headers
  if echo "${line}" | grep -qE '(Cookie|Set-Cookie):\s'; then
    emit_fatal "${line_num}" "cookie_header" "Cookie header detected"
  fi

  # Token-like high-entropy strings on their own line
  if [[ "${line_trimmed}" =~ ^[A-Za-z0-9+/=_-]{40,}$ ]] && ! contains_placeholder "${line_trimmed}"; then
    emit_fatal "${line_num}" "high_entropy_token" "High-entropy token-like string detected"
  fi

  # Absolute user paths
  if echo "${line}" | grep -qE '(^|[^"'"'"'A-Za-z0-9_.-])/Users/[A-Za-z]'; then
    if ! contains_placeholder "${line}"; then
      emit_fatal "${line_num}" "private_path" "Absolute macOS user path detected"
    fi
  fi

  if echo "${line}" | grep -qE '(^|[^"'"'"'A-Za-z0-9_.-])/home/[A-Za-z]'; then
    if ! contains_placeholder "${line}"; then
      emit_fatal "${line_num}" "private_path" "Absolute Linux home path detected"
    fi
  fi

  if echo "${line}" | grep -qiE 'C:\\Users\\'; then
    if ! contains_placeholder "${line}"; then
      emit_fatal "${line_num}" "private_path" "Windows profile path detected"
    fi
  fi

  # Private/internal hostnames (not in allowlist, not localhost)
  # Require at least two dots to avoid matching filenames like day1.md
  if echo "${line}" | grep -qoE '\b([a-zA-Z0-9][a-zA-Z0-9-]*\.){2,}[a-zA-Z]{2,}\b'; then
    hostnames=$(echo "${line}" | grep -oE '\b([a-zA-Z0-9][a-zA-Z0-9-]*\.){2,}[a-zA-Z]{2,}\b' | sort -u)
    while IFS= read -r host; do
      if [[ -z "${host}" ]]; then
        continue
      fi
      if is_allowlisted_host "${host}"; then
        continue
      fi
      if contains_placeholder "${host}"; then
        continue
      fi
      if [[ "${host}" == "localhost" || "${host}" == "127.0.0.1" ]]; then
        continue
      fi
      if [[ "${host}" =~ ^example\.(com|org|net)$ ]]; then
        continue
      fi
      emit_fatal "${line_num}" "private_hostname" "Non-allowlisted hostname: ${host}"
    done <<< "${hostnames}"
  fi

  # Raw JSON response detection
  # Detect JSON object/array containing API-like response data keys
  # (id, title, body, comments, data, result) that is not using redaction placeholders.
  if echo "${line_trimmed}" | grep -qiE '"(id|title|body|comments|data|result|status|message)"\s*:'; then
    if ! contains_placeholder "${line}"; then
      # Line contains JSON-like { ... "key":"val" ... } structure with body data
      if echo "${line_trimmed}" | grep -qE '\{.+\}'; then
        emit_fatal "${line_num}" "raw_response" "Raw JSON response block without redaction placeholder"
      fi
    fi
  fi

  # Non-allowlisted identifiers matching documented syntaxes
  # Pattern: ISSUE-NNN, WIKI-NNN, DOC-NNN, TASK-NNNN, PRJ-NNN, owner/repo
  if echo "${line}" | grep -qoE '\b([A-Z][A-Z0-9]*-[0-9]{2,}|[a-z]+:[A-Za-z0-9_-]+|[A-Za-z0-9_-]+/[A-Za-z0-9_-]+)\b'; then
    identifiers=$(echo "${line}" | grep -oE '\b([A-Z][A-Z0-9]*-[0-9]{2,}|[a-z]+:[A-Za-z0-9_-]+|[A-Za-z0-9_-]+/[A-Za-z0-9_-]+)\b' | sort -u)
    while IFS= read -r ident; do
      if [[ -z "${ident}" ]]; then
        continue
      fi
      if is_allowlisted_id "${ident}"; then
        continue
      fi
      if contains_placeholder "${ident}"; then
        continue
      fi
      if [[ "${ident}" =~ ^[0-9]+$ ]]; then
        continue
      fi
      if [[ "${ident}" =~ ^(gitcode|mcp|http|json|rpc|github|pass|fail|day[0-9]|md|sh|bash|yaml)$ ]]; then
        continue
      fi
      if [[ "${ident}" =~ ^([A-Z][a-z]+:)$ ]]; then
        continue
      fi
      # Heuristic: if it looks like a known identifier pattern but isn't allowlisted
      if [[ "${ident}" =~ ^([A-Z]{2,}[A-Z0-9]*-[0-9]{2,}|[a-z]+:[A-Z][a-z]+)$ ]]; then
        emit_fatal "${line_num}" "unallowlisted_id" "Non-allowlisted repo/tracker/wiki identifier: ${ident}"
      fi
    done <<< "${identifiers}"
  fi

done < "${feedback_file}"

if [[ ${fatal_count} -gt 0 ]]; then
  printf 'check-dogfood-feedback: %d fatal finding(s)\n' "${fatal_count}" >&2
fi
if [[ ${warn_count} -gt 0 ]]; then
  printf 'check-dogfood-feedback: %d warning(s)\n' "${warn_count}" >&2
fi
if [[ ${fatal_count} -eq 0 && ${warn_count} -eq 0 ]]; then
  printf 'check-dogfood-feedback: PASS\n' >&2
fi

if [[ ${fatal_count} -gt 0 ]]; then
  exit 1
fi
exit 0
